doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Contact Imraz Mohamed Farook')
        meta(name='author', content='Imraz Mohamed Farook')

        title Contact | Imraz Mohamed Farook

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        include includes/css.pug

    body.d-flex.flex-column.h-100.bg-light

        main.flex-shrink-0

            // Navigation
            include includes/navbar.pug

            // Contact Section
            section.py-5
                .container.px-5
                    .bg-light.rounded-4.py-5.px-4.px-md-5.shadow-sm

                        .text-center.mb-5
                            .feature.bg-primary.bg-gradient-primary-to-secondary.text-white.rounded-3.mb-3
                                i.bi.bi-envelope

                            h1.fw-bolder Get In Touch

                            p.lead.fw-normal.text-muted.mb-0
                                | Open to engineering, biomedical technology, and research opportunities.

                        .row.justify-content-center
                            .col-lg-8.col-xl-6.text-center

                                p.text-muted.mb-4
                                    | Feel free to reach out regarding collaborations, engineering opportunities, research projects, or professional connections.

                                // Email Button
                                a.btn.btn-primary.btn-lg.px-5.py-3.fs-6.fw-bolder.mb-4(
                                    href='mailto:Imrazfarook@hotmail.com?subject=Portfolio%20Inquiry'
                                )
                                    i.bi.bi-envelope-fill.me-2
                                    | Email Me

                                // Contact Information
                                .mb-4
                                    p.fs-5.mb-2
                                        strong Email:
                                    p.text-muted
                                        | Imrazfarook@hotmail.com

                                // Social Links
                                .d-flex.justify-content-center.fs-2.gap-4

                                    a.text-gradient(
                                        href='mailto:Imrazfarook@hotmail.com'
                                        title='Email'
                                    )
                                        i.bi.bi-envelope-fill

                                    a.text-gradient(
                                        href='https://www.linkedin.com/in/imrazmohamedfarook/'
                                        target='_blank'
                                        title='LinkedIn'
                                    )
                                        i.bi.bi-linkedin

                                    a.text-gradient(
                                        href='https://github.com/ImrazMohamedFarook'
                                        target='_blank'
                                        title='GitHub'
                                    )
                                        i.bi.bi-github

        // Footer
        include includes/footer.pug

        include includes/scripts.pug